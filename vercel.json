{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.js"
        }
    ],
    "functions": {
        "api/index.js": {
            "memory": 512,
            "maxDuration": 60,
            "runtime": "nodejs18.x"
        }
    },
    "env": {
        "GITHUB_TOKEN": "@github_token",
        "NODE_ENV": "production"
    }
}